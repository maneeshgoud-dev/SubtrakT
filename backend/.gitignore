# Dependencies (Never commit these, they block the repo and are rebuilt via npm install)
node_modules/
jspm_packages/
web_modules/

# Production build outputs
dist/
build/

# Debug and log files
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Environmental variables and local secrets (Crucial for security)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.local

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data and processes
pids
*.pid
*.seed
*.pid.lock

# Optional: IDE and OS files (Can also be ignored globally)
.DS_Store
Thumbs.db
.vscode/
.idea/
